{
  "name": "@cazala/automata",
  "version": "0.0.0-development",
  "description": "A library for building cellular automata simulations with WebGPU: neural CA (worms), Gray-Scott reaction-diffusion, Lenia, an 18-type pokemon battle CA, life-like and elementary (Wolfram) rules \u2014 plus a small framework for writing custom rules in WGSL with realtime parameter tuning.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "cellular-automata",
    "webgpu",
    "gpu-compute",
    "simulation",
    "neural-cellular-automata",
    "reaction-diffusion",
    "gray-scott",
    "lenia",
    "conway",
    "game-of-life",
    "elementary-ca",
    "wolfram",
    "wgsl",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cazala/automata.git",
    "directory": "packages/core"
  },
  "homepage": "https://caza.la/automata/",
  "bugs": {
    "url": "https://github.com/cazala/automata/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "author": "cazala",
  "license": "MIT",
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^11.1.0",
    "@webgpu/types": "^0.1.64",
    "rollup": "^4.0.0",
    "tslib": "^2.6.0",
    "typescript": "~5.6.3"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
